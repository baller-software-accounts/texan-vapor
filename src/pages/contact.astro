---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact Us — Texan Vapor & CBD"
  description="Get in touch with Texan Vapor & CBD in Forney, TX. Call us, stop by, or send us a message — we're here to help."
>
  <!-- Page Hero -->
  <section class="relative overflow-hidden py-20 sm:py-28">
    <img
      src="https://images.unsplash.com/photo-1523966211575-eb4a01e7dd51?w=1920&auto=format&fit=crop&q=80"
      alt="Vintage telephone for contact"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/70 to-slate-900/40"></div>
    <div class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-[--color-primary-light]">Get In Touch</p>
      <h1 class="mt-3 text-4xl font-bold text-white sm:text-5xl">Contact Us</h1>
      <p class="mt-4 max-w-xl text-lg text-slate-300">
        Have a question or need help finding the right product? We'd love to hear from you.
      </p>
    </div>
  </section>

  <!-- Contact Info Cards — overlapping the hero -->
  <div class="relative z-10 -mt-10 mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      <!-- Address -->
      <div class="rounded-2xl bg-white border border-[--color-border] p-6 shadow-[--shadow-xl]">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-blue-100 text-blue-600 mb-4">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-[--color-text-primary]">Visit Us</h3>
        <address class="mt-2 not-italic text-sm text-[--color-text-secondary] leading-relaxed">
          1102 Ranch Rd. Ste 218<br />
          Forney, TX 75126
        </address>
      </div>

      <!-- Phone -->
      <div class="rounded-2xl bg-white border border-[--color-border] p-6 shadow-[--shadow-xl]">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-emerald-100 text-emerald-600 mb-4">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-[--color-text-primary]">Call Us</h3>
        <a href="tel:+19453304500" class="mt-2 block text-sm text-[--color-primary] hover:text-[--color-primary-dark] font-medium">
          (945) 330-4500
        </a>
        <p class="mt-1 text-xs text-[--color-text-secondary]">Mon–Sat: 9 AM – 9 PM<br/>Sun: 11 AM – 7 PM</p>
      </div>

      <!-- Hours -->
      <div class="rounded-2xl bg-white border border-[--color-border] p-6 shadow-[--shadow-xl]">
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-amber-100 text-amber-600 mb-4">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </div>
        <h3 class="text-sm font-semibold text-[--color-text-primary]">Store Hours</h3>
        <ul class="mt-2 space-y-1 text-xs text-[--color-text-secondary]">
          <li class="flex justify-between gap-2"><span>Mon – Fri</span><span class="font-medium text-[--color-text-primary]">9 AM – 9 PM</span></li>
          <li class="flex justify-between gap-2"><span>Saturday</span><span class="font-medium text-[--color-text-primary]">9 AM – 9 PM</span></li>
          <li class="flex justify-between gap-2"><span>Sunday</span><span class="font-medium text-[--color-text-primary]">11 AM – 7 PM</span></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Contact Form + Map Section -->
  <section class="bg-[--color-surface] pt-20 pb-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-16">
        <!-- Form -->
        <div>
          <p class="text-sm font-semibold uppercase tracking-wider text-[--color-primary]">Send a Message</p>
          <h2 class="mt-2 text-2xl font-bold text-[--color-text-primary]">We'd Love to Hear From You</h2>
          <p class="mt-3 text-[--color-text-secondary]">
            Fill in the form and we'll get back to you as soon as possible — usually within one business day.
          </p>
          <div class="mt-8">
            <ContactForm endpoint="https://formspree.io/f/YOUR_FORM_ID" />
          </div>
        </div>

        <!-- Map / Info -->
        <div class="flex flex-col gap-8">
          <div>
            <p class="text-sm font-semibold uppercase tracking-wider text-[--color-primary]">Find Us</p>
            <h2 class="mt-2 text-2xl font-bold text-[--color-text-primary]">Our Location</h2>
            <p class="mt-3 text-[--color-text-secondary]">
              Conveniently located on Ranch Road in Forney, TX. Easy parking available.
            </p>
          </div>

          <!-- Google Maps embed placeholder -->
          <div class="overflow-hidden rounded-2xl border border-[--color-border] bg-slate-100 aspect-video">
            <iframe
              title="Texan Vapor & CBD location map"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3353.4!2d-96.47!3d32.74!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x864ea99b5c2e4c4d%3A0x1234567890abcdef!2s1102%20Ranch%20Rd%20Ste%20218%2C%20Forney%2C%20TX%2075126!5e0!3m2!1sen!2sus!4v1234567890"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>

          <!-- Facebook link -->
          <div class="rounded-2xl border border-[--color-border] bg-white p-6">
            <h3 class="text-sm font-semibold text-[--color-text-primary] mb-2">Follow Us on Facebook</h3>
            <p class="text-sm text-[--color-text-secondary] mb-4">Stay up to date with our latest products, promotions, and store news.</p>
            <a
              href="https://www.facebook.com/61577974100271/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg bg-[#1877F2] px-4 py-2 text-sm font-semibold text-white hover:opacity-90 transition-opacity"
            >
              <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
              </svg>
              Texan Vapor &amp; CBD
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
