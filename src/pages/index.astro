---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const valueProps = [
  {
    icon: 'star',
    color: 'emerald',
    title: 'Wide Selection',
    description: 'Hundreds of vaping devices, e-liquids, CBD products, and accessories all under one roof.',
  },
  {
    icon: 'tag',
    color: 'blue',
    title: 'Unbeatable Prices',
    description: 'Competitive pricing on top brands without compromising on quality — we beat any local price.',
  },
  {
    icon: 'user',
    color: 'amber',
    title: 'Expert Staff',
    description: 'Knowledgeable, friendly team ready to help you find exactly what you need — every visit.',
  },
  {
    icon: 'map',
    color: 'sky',
    title: 'Local & Trusted',
    description: 'Proudly serving Forney and surrounding communities including Wills Point and Seagoville.',
  },
];

const services = [
  {
    image: 'https://images.unsplash.com/photo-1522741070277-b1b2ba3a7bd3?w=800&auto=format&fit=crop&q=80',
    title: 'Vape Products',
    description: 'A full range of vaping devices, mods, pod systems, and e-liquids from leading brands. Whether you\'re a beginner or an enthusiast, we have you covered.',
  },
  {
    image: 'https://images.unsplash.com/photo-1600753230816-94fc22e82859?w=800&auto=format&fit=crop&q=80',
    title: 'CBD & Hemp',
    description: 'High-quality hemp-derived CBD oils, tinctures, edibles, and topicals. Our staff can walk you through the options and find the right fit for your needs.',
  },
  {
    image: 'https://images.unsplash.com/photo-1547652577-b4fe2f34d7ee?w=800&auto=format&fit=crop&q=80',
    title: 'Tobacco & Cigars',
    description: 'Traditional tobacco products, premium cigars, rolling supplies, and pipe tobacco for those who appreciate classic smoking culture.',
  },
  {
    image: 'https://images.unsplash.com/photo-1545114687-ab1c9f9fc260?w=800&auto=format&fit=crop&q=80',
    title: 'Smoke Shop',
    description: 'Head shop accessories, pipes, rolling papers, grinders, and more. Everything you need, all in one convenient Forney location.',
  },
];

const stats = [
  { value: '5.0 ★', label: 'Yelp & Google Rating' },
  { value: '500+', label: 'Happy Customers' },
  { value: '4+', label: 'Years Serving Forney' },
  { value: 'Daily', label: 'Open 7 Days a Week' },
];
---

<BaseLayout title="Texan Vapor & CBD — Forney's Premier Vape & Smoke Shop">
  <!-- Hero Section -->
  <section class="relative min-h-[85vh] flex items-center overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1529567591152-9abba27ab13b?w=1920&auto=format&fit=crop&q=80"
      alt="Vapor clouds from vape devices"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-slate-900/90 via-slate-900/70 to-slate-900/40"></div>
    <div class="relative z-10 mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8 py-24">
      <div class="max-w-xl">
        <!-- Status badge -->
        <div class="mb-6 inline-flex items-center gap-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 px-4 py-2 text-sm text-white">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
          </span>
          Now Open in Forney, TX
        </div>

        <h1 class="text-4xl font-bold leading-tight text-white sm:text-5xl lg:text-6xl">
          Your Local Vape &amp;<br/>CBD Destination
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-300">
          Forney's trusted source for premium vaping products, CBD, hemp items, and tobacco accessories. Expert staff, unbeatable prices, and an incredible selection — all under one roof.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a
            href={`${base}/contact`}
            class="flex items-center justify-center gap-2 rounded-lg bg-[--color-primary] px-6 py-3 text-base font-semibold text-white shadow-lg transition-all duration-[--duration-medium] hover:bg-[--color-primary-dark] hover:-translate-y-0.5 hover:shadow-xl"
          >
            Get in Touch
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </a>
          <a
            href="tel:+19453304500"
            class="flex items-center justify-center gap-2 rounded-lg border-2 border-white/30 px-6 py-3 text-base font-semibold text-white transition-all duration-[--duration-medium] hover:bg-white/10 hover:-translate-y-0.5"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
            </svg>
            Call (945) 330-4500
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="relative z-10 mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 -mt-12">
    <div class="rounded-2xl bg-white border border-[--color-border] p-6 shadow-[--shadow-xl]">
      <div class="grid grid-cols-2 gap-6 lg:grid-cols-4">
        {stats.map(stat => (
          <div class="text-center">
            <p class="text-2xl font-bold text-[--color-text-primary]">{stat.value}</p>
            <p class="mt-1 text-sm text-[--color-text-secondary]">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Value Proposition Section -->
  <section class="bg-white py-24 mt-6">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-[--color-primary]">Why Choose Us</p>
        <h2 class="mt-2 text-3xl font-bold text-[--color-text-primary] sm:text-4xl">The Texan Vapor Difference</h2>
        <p class="mx-auto mt-4 max-w-2xl text-[--color-text-secondary]">
          We're more than a smoke shop — we're your neighborhood experts for all things vape, CBD, and beyond.
        </p>
      </div>

      <div class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {valueProps.map(prop => (
          <div class="group relative rounded-2xl border border-[--color-border] bg-white p-6 transition-all duration-[--duration-slow] hover:-translate-y-1 hover:shadow-lg">
            <div class={`mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-${prop.color}-100 text-${prop.color}-600 transition-transform duration-[--duration-slow] group-hover:scale-110`}>
              {prop.icon === 'star' && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
                </svg>
              )}
              {prop.icon === 'tag' && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" />
                </svg>
              )}
              {prop.icon === 'user' && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                </svg>
              )}
              {prop.icon === 'map' && (
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
              )}
            </div>
            <h3 class="text-lg font-semibold text-[--color-text-primary]">{prop.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[--color-text-secondary]">{prop.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services Overview Section -->
  <section class="bg-[--color-surface] py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-[--color-primary]">What We Offer</p>
        <h2 class="mt-2 text-3xl font-bold text-[--color-text-primary] sm:text-4xl">Our Products & Services</h2>
        <p class="mx-auto mt-4 max-w-2xl text-[--color-text-secondary]">
          From beginner starter kits to advanced setups, CBD wellness products to classic tobacco — we carry it all.
        </p>
      </div>

      <div class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {services.map(service => (
          <div class="group overflow-hidden rounded-2xl border border-[--color-border] bg-white transition-all duration-[--duration-slow] hover:-translate-y-1 hover:shadow-lg">
            <div class="relative h-48 overflow-hidden">
              <img
                src={service.image}
                alt={service.title}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>
            </div>
            <div class="p-6">
              <h3 class="text-lg font-semibold text-[--color-text-primary]">{service.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-[--color-text-secondary]">{service.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonial Section -->
  <section class="bg-white py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-[--color-primary]">Customer Reviews</p>
        <h2 class="mt-2 text-3xl font-bold text-[--color-text-primary] sm:text-4xl">What Our Customers Say</h2>
      </div>
      <div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
        {[
          { quote: 'Fantastic Vape Shop! Great selection, friendly staff, and unbeatable prices! The team is always helpful and knowledgeable.', source: 'Google Review' },
          { quote: 'Best vape shop in Forney! They always have what I need and the prices are amazing. Highly recommend to anyone in the area.', source: 'Yelp Review' },
          { quote: 'I drive from Wills Point just to shop here. The staff knows their products and makes every visit a great experience.', source: 'Yahoo Local Review' },
        ].map(t => (
          <div class="relative rounded-2xl border border-[--color-border] bg-white p-8">
            <svg class="absolute top-6 right-6 h-8 w-8 text-[--color-primary]/10" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>
            <div class="mb-4 flex gap-1">
              {[...Array(5)].map(() => (
                <svg class="h-4 w-4 text-amber-400" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292Z" />
                </svg>
              ))}
            </div>
            <blockquote class="text-[--color-text-primary] leading-relaxed" style="line-height: 1.7">
              "{t.quote}"
            </blockquote>
            <p class="mt-4 text-sm font-medium text-[--color-text-secondary]">— {t.source}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative overflow-hidden py-24">
    <img
      src="https://images.unsplash.com/photo-1687114835860-4c22e258781f?w=1920&auto=format&fit=crop&q=80"
      alt="Local neighborhood storefront"
      class="absolute inset-0 h-full w-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[--color-primary]/95 via-[--color-primary]/90 to-[--color-primary-dark]/90"></div>
    <div class="relative z-10 mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">Ready to Visit?</h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-blue-100">
        Stop by our Forney location or give us a call. We're open 7 days a week and always happy to help.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href={`${base}/contact`}
          class="flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-base font-semibold text-[--color-primary] shadow transition-all duration-[--duration-medium] hover:-translate-y-0.5 hover:shadow-lg"
        >
          Get in Touch
        </a>
        <a
          href="tel:+19453304500"
          class="flex items-center gap-2 rounded-lg border-2 border-white/30 px-6 py-3 text-base font-semibold text-white transition-all duration-[--duration-medium] hover:bg-white/10 hover:-translate-y-0.5"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
          </svg>
          Call (945) 330-4500
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
